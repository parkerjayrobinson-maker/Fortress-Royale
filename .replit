modules = ["nodejs-24"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5050
externalPort = 3002

[[ports]]
localPort = 26079
externalPort = 3001

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/ffa-shooter && PORT=5000 BASE_PATH=/ pnpm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[deployment]
deploymentTarget = "vm"
build = ["bash", "-lc", "PORT=5000 BASE_PATH=/ pnpm install --frozen-lockfile=false && PORT=5000 BASE_PATH=/ pnpm --filter @workspace/ffa-shooter run build && pnpm --filter @workspace/api-server run build && rm -rf artifacts/api-server/public && cp -r artifacts/ffa-shooter/dist/public artifacts/api-server/public"]
publicDir = "artifacts/ffa-shooter/dist/public"
run = ["bash", "-lc", "node artifacts/api-server/dist/index.mjs"]
